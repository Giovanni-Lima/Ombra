<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Ombra.Models;assembly=Ombra.Core"
             x:Class="Ombra.MainPage"
             Title="Mappa stabilimento"
             BackgroundColor="{StaticResource Sabbia}">

    <Grid Padding="16" RowDefinitions="Auto,*" RowSpacing="12">

        <Label Grid.Row="0"
               Text="Mappa stabilimento"
               FontFamily="Rockwell"
               FontSize="24"
               TextColor="{StaticResource NotteMarina}" />

        <CollectionView x:Name="OmbrelloniCollectionView" Grid.Row="1" ItemsSource="{Binding Ombrelloni}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Ombrellone">
                    <Border StrokeShape="RoundRectangle 12"
                            Stroke="{StaticResource NotteMarina}"
                            StrokeThickness="1"
                            BackgroundColor="{Binding Stato, Converter={StaticResource StatoToColorConverter}}"
                            Padding="8"
                            HeightRequest="72">
                        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="0">
                            <Label Text="{Binding Fila}"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   TextColor="{Binding Stato, Converter={StaticResource StatoToTextColorConverter}}"
                                   HorizontalOptions="Center" />
                            <Label Text="{Binding Numero}"
                                   FontFamily="Consolas"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   TextColor="{Binding Stato, Converter={StaticResource StatoToTextColorConverter}}"
                                   HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>

</ContentPage>
